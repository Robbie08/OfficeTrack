<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/topAppBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/ot_surface"
        app:title="Office Track"
        app:titleCentered="true"
        app:titleTextColor="@color/ot_text_primary" />

    <ScrollView
        android:id="@+id/mainScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/mainContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="32dp"
            android:paddingBottom="32dp">

            <TextView
                android:id="@+id/statusHeaderTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Status"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/inOfficeSinceTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="In office since 8:42 AM"
                android:textSize="16sp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/currentSessionTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Current session: 2h 15m"
                android:textSize="16sp"
                android:layout_marginBottom="24dp" />

            <TextView
                android:id="@+id/summaryHeaderTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Summary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/weeklyHeaderTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="This week"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/weeklyProgressTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="18h 30m / 24h"
                android:textSize="16sp"
                android:layout_marginTop="2dp" />

            <ProgressBar
                android:id="@+id/weeklyProgressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="0"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/weeklyRemainingTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Remaining: 5h 30m"
                android:textSize="16sp"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/monthlyHeaderTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="This month"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/monthlyProgressTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="62h 30m / 96h"
                android:textSize="16sp"
                android:layout_marginTop="2dp" />

            <ProgressBar
                android:id="@+id/monthlyProgressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="0"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/monthlyRemainingTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Remaining: 34h 30m"
                android:textSize="16sp"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="48dp" />

            <Button
                android:id="@+id/startSessionButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Start Session"
                android:backgroundTint="@color/ot_accent_blue"
                android:textColor="@color/ot_bg"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/endSessionButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="End Session"
                android:backgroundTint="@color/ot_accent_blue"
                android:textColor="@color/ot_bg"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/sessionHistoryButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Session History"
                android:backgroundTint="@color/ot_accent_blue"
                android:textColor="@color/ot_bg"
                />

        </LinearLayout>
    </ScrollView>

</LinearLayout>